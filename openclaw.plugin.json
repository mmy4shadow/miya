{
  "id": "miya",
  "name": "Miya",
  "description": "Minimal OpenClaw plugin scaffold for Miya with Phase 1-6 foundations.",
  "version": "0.2.0",
  "skills": ["./skill"],
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "enabled": { "type": "boolean", "default": true, "description": "Enable Miya command registrations." },
      "stateRoot": { "type": "string", "default": "F:\\openclaw" },
      "modelRoot": { "type": "string", "default": "F:\\openclaw\\miya\\model" },
      "pluginRoot": { "type": "string", "default": "F:\\openclaw\\miya" },
      "desktopWorker": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "enabled": { "type": "boolean", "default": false },
          "transport": { "type": "string", "enum": ["http", "command"], "default": "http", "description": "Desktop action transport. Use http for a loopback worker endpoint or command for the bundled local Python worker." },
          "endpoint": { "type": "string", "default": "http://127.0.0.1:43111" },
          "timeoutMs": { "type": "integer", "minimum": 500, "default": 3000 },
          "probe": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "mode": { "type": "string", "enum": ["http", "command", "none"], "default": "http" },
              "path": { "type": "string", "default": "/health" },
              "method": { "type": "string", "enum": ["GET", "POST"], "default": "GET" },
              "command": { "type": "string", "default": "" },
              "args": { "type": "array", "items": { "type": "string" }, "default": [] },
              "expectedStatus": { "type": "integer", "minimum": 100, "maximum": 599, "default": 200 }
            }
          }
        }
      },
      "desktopRun": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "enabled": { "type": "boolean", "default": true },
          "defaultConfirm": { "type": "boolean", "default": true },
          "persistRuns": { "type": "boolean", "default": true },
          "defaultMaxAttempts": { "type": "integer", "minimum": 1, "maximum": 5, "default": 1 }
        }
      },
      "features": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "probeCommand": { "type": "boolean", "default": true },
          "workerHealthCommand": { "type": "boolean", "default": true },
          "capabilitiesCommand": { "type": "boolean", "default": true },
          "memoryLite": { "type": "boolean", "default": false },
          "personaLite": { "type": "boolean", "default": false },
          "voiceLite": { "type": "boolean", "default": false },
          "vramScheduler": { "type": "boolean", "default": false },
          "wizard": { "type": "boolean", "default": false }
        }
      },
      "memoryLite": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "enabled": { "type": "boolean", "default": false },
          "provider": { "type": "string", "enum": ["core-memory", "local-embedding", "none"], "default": "core-memory" },
          "collection": { "type": "string", "default": "miya-memory-lite" },
          "maxRecallItems": { "type": "integer", "minimum": 1, "maximum": 20, "default": 4 },
          "fallbackStrategy": { "type": "string", "enum": ["identity-only", "core-only"], "default": "identity-only" }
        }
      },
      "personaLite": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "enabled": { "type": "boolean", "default": false },
          "profileName": { "type": "string", "default": "miya-default" },
          "styleTags": { "type": "array", "items": { "type": "string" }, "default": ["sweet", "playful", "clingy-lite"] },
          "referenceImageDir": { "type": "string", "default": "F:\\openclaw\\miya\\model\\image\\long_term" },
          "injectionMode": { "type": "string", "enum": ["static", "core-system", "none"], "default": "static" },
          "fallbackStrategy": { "type": "string", "enum": ["static-summary", "identity-only"], "default": "static-summary" }
        }
      },
      "voice": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "enabled": { "type": "boolean", "default": false },
          "tts": { "$ref": "#/$defs/voiceStageWithVoice" },
          "speakerId": { "$ref": "#/$defs/voiceStage" },
          "vad": { "$ref": "#/$defs/voiceStage" },
          "asr": { "$ref": "#/$defs/voiceStage" }
        }
      },
      "vramScheduler": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "enabled": { "type": "boolean", "default": false },
          "strategy": { "type": "string", "enum": ["manual-lanes", "none"], "default": "manual-lanes" },
          "defaultLane": { "type": "string", "enum": ["interactive", "voice", "vision", "image", "training"], "default": "interactive" },
          "gpuIndex": { "type": "integer", "minimum": 0, "default": 0 },
          "minFreeMb": { "type": "integer", "minimum": 0, "default": 1024 },
          "telemetryCommand": { "type": "string", "default": "nvidia-smi" },
          "telemetryArgs": { "type": "array", "items": { "type": "string" }, "default": [] },
          "allowForceEvict": { "type": "boolean", "default": false },
          "fragmentationSlackMb": { "type": "integer", "minimum": 0, "default": 512 },
          "evictionCommand": { "type": "string", "default": "" },
          "evictionArgs": { "type": "array", "items": { "type": "string" }, "default": [] },
          "defragCommand": { "type": "string", "default": "" },
          "defragArgs": { "type": "array", "items": { "type": "string" }, "default": [] },
          "lanes": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "lane": { "type": "string", "enum": ["interactive", "voice", "vision", "image", "training"] },
                "priority": { "type": "integer", "default": 0 },
                "maxModels": { "type": "integer", "minimum": 1, "default": 1 },
                "estimatedVramMb": { "type": "integer", "minimum": 0, "default": 0 },
                "evictable": { "type": "boolean", "default": true }
              },
              "required": ["lane"]
            },
            "default": []
          }
        }
      },
      "vision": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "enabled": { "type": "boolean", "default": true },
          "provider": { "type": "string", "enum": ["auto", "sidecar", "command", "none"], "default": "auto" },
          "command": { "type": "string", "default": "" },
          "args": { "type": "array", "items": { "type": "string" }, "default": [] },
          "pythonCommand": { "type": "string", "default": "python" },
          "sidecarPath": { "type": "string", "default": "F:\\openclaw\\miya\\worker\\vision_sidecar.py" },
          "modelPath": { "type": "string", "default": "F:\\openclaw\\miya\\model\\vision\\qwen3vl_4b_instruct_q4_k_m" },
          "runtimeRoot": { "type": "string", "default": "F:\\openclaw\\miya\\runtime\\vision\\llama.cpp" },
          "binaryPath": { "type": "string", "default": "" },
          "mmprojPath": { "type": "string", "default": "" },
          "gpuLayers": { "type": "integer", "minimum": 0, "default": 99 },
          "timeoutMs": { "type": "integer", "minimum": 1000, "default": 60000 }
        }
      },
      "image": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "enabled": { "type": "boolean", "default": true },
          "provider": { "type": "string", "enum": ["sidecar", "python", "none"], "default": "sidecar" },
          "pythonCommand": { "type": "string", "default": "python" },
          "sidecarPath": { "type": "string", "default": "F:\\openclaw\\miya\\worker\\image_sidecar.py" },
          "modelPreference": { "type": "string", "enum": ["fast", "balanced"], "default": "balanced" },
          "timeoutMs": { "type": "integer", "minimum": 1000, "default": 180000 }
        }
      },
      "wizard": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "enabled": { "type": "boolean", "default": false },
          "workspaceDir": { "type": "string", "default": "F:\\openclaw\\miya\\state\\wizard" },
          "datasetDir": { "type": "string", "default": "F:\\openclaw\\miya\\state\\wizard\\datasets" },
          "outputDir": { "type": "string", "default": "F:\\openclaw\\miya\\state\\wizard\\jobs" },
          "trainer": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "lora": { "$ref": "#/$defs/trainerProfile" },
              "finetune": { "$ref": "#/$defs/trainerProfile" }
            }
          }
        }
      }
    },
    "$defs": {
      "voiceStage": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "enabled": { "type": "boolean", "default": false },
          "provider": { "type": "string", "enum": ["external-worker", "manual", "none"], "default": "manual" },
          "modelPath": { "type": "string", "default": "" },
          "sampleRate": { "type": "integer", "minimum": 8000, "default": 16000 }
        }
      },
      "voiceStageWithVoice": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "enabled": { "type": "boolean", "default": false },
          "provider": { "type": "string", "enum": ["external-worker", "manual", "none"], "default": "manual" },
          "modelPath": { "type": "string", "default": "" },
          "sampleRate": { "type": "integer", "minimum": 8000, "default": 24000 },
          "voiceId": { "type": "string", "default": "Vivian" }
        }
      },
      "trainerProfile": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "enabled": { "type": "boolean", "default": false },
          "command": { "type": "string", "default": "" },
          "args": { "type": "array", "items": { "type": "string" }, "default": [] },
          "cwd": { "type": "string", "default": "" },
          "artifactGlobs": { "type": "array", "items": { "type": "string" }, "default": ["**/*.safetensors", "**/*.bin", "**/*.json"] },
          "env": {
            "type": "object",
            "default": {},
            "additionalProperties": { "type": "string" }
          }
        }
      }
    }
  },
  "uiHints": {
    "enabled": { "label": "Enable Miya foundations" },
    "stateRoot": { "label": "OpenClaw state root", "placeholder": "F:\\openclaw" },
    "modelRoot": { "label": "Miya model root", "placeholder": "F:\\openclaw\\miya\\model" },
    "pluginRoot": { "label": "Miya plugin root", "placeholder": "F:\\openclaw\\miya" },
    "vision.modelPath": { "label": "Vision model path", "placeholder": "F:\\openclaw\\miya\\model\\vision\\qwen3vl_4b_instruct_q4_k_m" }
  }
}
